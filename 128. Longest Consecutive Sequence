class Solution{
public int longestConsecutiveSum(int[]nums){
HashSet<Integer>set=new HashSet<>();
for(int num:nums){
set.add(num);
}
int longest=0;
for(int num:set){
if(!set.contains(num-1){
int largest=1;
int current=num;
while(set.contains(num+1)){
largest++;
current++;
}
longest=Math.max(longest,largest);
}
}
longest=Math.max(longest,largest);
}
return longest;
}
}
