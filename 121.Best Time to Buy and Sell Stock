class Solution {
    public int maxProfit(int[] prices) {
        int minPrice = Integer.MAX_VALUE;
        int maxValue=0;
        for(int price : prices){
            if(price<minPrice){
                minPrice=price;
            }
            else if(price-minPrice>maxValue){
                maxValue=price-minPrice;
            }
        }
        return maxValue;
    }
}
