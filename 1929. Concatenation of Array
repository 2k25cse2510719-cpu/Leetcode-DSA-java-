class Solution {
    public int[] getConcatenation(int[] nums) {
        int[]ans=new int [2*nums.length];
        int k=nums.length;
        for(int i =0 ;i<nums.length;i++){
ans[i]=nums[i];
        }
        for(int i =0 ;i<nums.length;i++){
ans[i+k]=nums[i];
        }
        return ans;
    }
}
