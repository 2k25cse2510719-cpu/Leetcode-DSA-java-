class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int sum=0;
        int average=0;
        for(int i=0;i<k;i++){
            sum=sum+nums[i];
        }
        int left=0;
        int max=sum;
        for(int right=k;right<nums.length;right++){
            left=right-k;
            sum=sum+nums[right]-nums[left];
            max=Math.max(max,sum);
        }
        return (double)max/k;
    }
}
